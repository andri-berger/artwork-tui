
$default-0: $surface-lighten-1;
$default: $surface;
$defaults: transparent;
$brand: $primary;


Screen {
    align: center middle;
    background: $default;
    color: ansi_default;
    layers: base overlay;
}

ModalScreen {
    offset: 1% 1%;
    width: 10%;
    height: 10%;
    background: $defaults;
}







TableApp {
    align: center middle;
    background: $defaults;
    width: 90%;
    height: 80%;
}

ImageTab {
    align: center middle;
    background: $defaults;
    max-width: 120;
    height: 1fr;
    width: 1fr;
}



#top {
    width: 1fr;
    height: 2fr;
    align: center middle; }

#bottom {
    width: 1fr;
    height: 1fr;
    align: center middle;
}

#status {
    width: 1fr;
    height: 5;
    align: center middle;
}

#bottoms {
    width: 1fr;
    height: 2;
    background: $defaults;
    align: center middle;
}

#label-0 {
    width: 90;
    height: 1fr;
    text-align: center;
    background: $defaults;
}


#first {
  border: hkey $brand;
    text-style: bold;
    width: 10;
    background: transparent;
}

#second {
  border: hkey white;
    width: auto;
    background: $defaults;
    padding: 0 0;
}


#fourth {
  border: hkey white;
    width: 9;
    background: $defaults;
    text-align: center;
    padding-left: 0;
}

#third {
  border: hkey white;
    width: 30;
    background: $defaults;
    text-align: center;
    padding-left: 0;
}

#first > .input--placeholder {
    color: $text;
}













#cont-switch-0 {
    width: 22;
    height: 1fr; }

DirectoryTree {
offset: 0 0;
     background: $defaults; }

DirectoryTree > .tree--cursor {
    background: $brand;
     padding: 0;}
DirectoryTree > .tree--guides {
    padding: 0;}
DirectoryTree > .tree--guides-hover {
    padding: 0;}
DirectoryTree > .tree--guides-selected {
    padding: 0;}
DirectoryTree > .tree--highlight {
    padding: 0; }
DirectoryTree > .tree--highlight-line {
    padding: 0;}
DirectoryTree > .tree--label {
    padding: 0;}





#cont-switch-1 {
    background: $defaults;
    max-width: 90;
    width: 1fr;
    height: 1fr; }

DataTable {
    background: $defaults; }

DataTable,
#dir-tree-0,
#dir-tree-1,
 #dir-tree-2 {
    scrollbar-visibility: hidden;
}

DataTable > .datatable--cursor,
DataTable > .datatable--header-cursor,
DataTable > .datatable--fixed-cursor {
    background: $brand;
}

DataTable > .datatable--hover,
DataTable > .datatable--header-hover {
    background: $brand;
}

DataTable > .datatable--header,
 DataTable > .datatable--fixed {
    background: $defaults;
}

DataTable > .datatable--even-row {
    background: $default-0;
}

DataTable > .datatable--odd-row {
    background: $defaults;
}

Input {
    border: hkey white; }


Button {
    text-style: none;
    padding: 0;
    min-width: 0;
    border: hkey white; }

#digits-0 {
    width: auto;
    height: 1fr;
    }








DirectoryTree,
DataTable {
    border: hkey white;
}

Button:focus,
DirectoryTree:focus,
DataTable:focus {
    background: $defaults;
    border: hkey $brand;
}

Horizontal,
DirectoryTree,
ContentSwitcher {
    layer: base;
}

Digits {
layer: overlay;
dock: left;
}


Digits {
    color: white;
}



