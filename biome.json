{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"assist": {
		"actions": {
			"source": { "organizeImports": "off" }
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"noUselessUndefinedInitialization": "off"
			},
			"style": {
				"useConst": "off",
				"noDescendingSpecificity": "off"
			},
			"a11y": {
				"useGenericFontNames": "off"
			}
		}
	},
	"formatter": {
		"indentWidth": 2,
		"indentStyle": "tab"
	},
	"files": {
		"includes": [
			"Fontend/*.js",
			"Fontend/*.css",
			"Fontend/*.json",
			"!Fontend/model.js"
		]
	},
	"javascript": {
		"formatter": {
            "enabled": true,
			"lineWidth": 50,
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
            "lineWidth": 50
		}
	},
	"css": {
		"formatter": {
			"enabled": true,
            "lineWidth": 40
		}
	}
}
